# ===========================================
# 必要环境变量（缺失将导致应用无法访问）
# ===========================================

# GitHub OAuth 配置
# 在 GitHub → Settings → Developer settings → OAuth Apps 获取
GITHUB_CLIENT_ID=your_client_id
GITHUB_CLIENT_SECRET=your_client_secret

# JWT 密钥（用于用户认证会话签名）
# 生成命令: openssl rand -hex 32
JWT_SECRET=your_jwt_secret

# 加密密钥（用于加密存储私钥和验证 Webhook 签名）
# 生成命令: openssl rand -hex 32
ENCRYPTION_KEY=your_encryption_key

# 数据库连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://user:password@localhost:5432/manticore

# ===========================================
# GitHub App 配置（可选，用于 CI/CD 功能）
# ===========================================

# GitHub App ID（在 App 设置页顶部获取）
GITHUB_APP_ID=123456

# GitHub App Slug（用于机器人 @mention 匹配）
GITHUB_APP_SLUG=your-app-slug

# GitHub App 私钥文件路径
GITHUB_PRIVATE_KEY_PATH=./private-key.pem

# ===========================================
# Qwen Code 配置（AI 自动化引擎）
# ===========================================

# Qwen Code API 密钥（用于 Issue 自动修复、PR 安全审计、定时扫描）
# 从 https://open.bigmodel.cn 获取或使用兼容 API
UNLIMITED_OPENAI_API_KEY=your_api_key

# Qwen Code 全局配置（JSON 格式，写入 ~/.qwen/settings.json）
QWEN_SETTINGS_JSON={"api_key":"your_api_key","model":"qwen-plus"}

# 定时扫描触发 Token（可选，用于外部 cron 触发 /api/ci/scan）
SCAN_TRIGGER_TOKEN=your_scan_token

# ===========================================
# 应用配置
# ===========================================

# 应用公开地址（用于 OAuth 回调）
APP_URL=http://localhost:3001
