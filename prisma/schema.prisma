// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 管理员表
model Admin {
  id          Int      @id @default(autoincrement())
  githubId    Int      @unique
  githubLogin String   @unique @map("github_login")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  lastLogin   DateTime @default(now()) @map("last_login")

  builds       Build[]
  installations GitHubInstallation[]
  repoConfigs  RepoConfig[]
  apiKeys      ApiKey[]
  runners      GitHubRunner[]

  @@map("admins")
}

// 应用配置表
model AppConfig {
  id          Int      @id @default(autoincrement())
  configKey   String   @unique @map("config_key")
  configValue String   @map("config_value")
  encrypted   Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("app_config")
}

// CI 运行日志表
model CiRun {
  id              Int       @id @default(autoincrement())
  repoFullName    String    @map("repo_full_name")
  event           String
  action          String?
  branch          String?
  commitSha       String?   @map("commit_sha")
  prNumber        Int?      @map("pr_number")
  status          String    @default("pending")
  conclusion      String?
  triggeredBy     String?   @map("triggered_by")
  ruleId          String?   @map("rule_id")
  checksRan       String[]  @default([]) @map("checks_ran")
  logs            String?
  isBotInitiated  Boolean   @default(false) @map("is_bot_initiated")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  duration        Int?                            // 毫秒
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([repoFullName])
  @@index([createdAt])
  @@index([status])
  @@index([isBotInitiated])
  @@map("ci_runs")
}

// 构建记录表
model Build {
  id            Int       @id @default(autoincrement())
  prNumber      Int       @map("pr_number")
  branchName    String    @map("branch_name")
  triggerUser   String    @map("trigger_user")
  startedAt     DateTime  @map("started_at")
  completedAt   DateTime? @map("completed_at")
  status        String
  totalDuration Int?      @map("total_duration")
  createdAt     DateTime  @default(now()) @map("created_at")

  admin   Admin? @relation(fields: [triggerUser], references: [githubLogin])
  steps   BuildStep[]

  @@index([prNumber])
  @@index([createdAt])
  @@map("builds")
}

// 构建步骤表
model BuildStep {
  id        Int      @id @default(autoincrement())
  buildId   Int      @map("build_id")
  stepName  String   @map("step_name")
  status    String
  duration  Int?
  exitCode  Int?     @map("exit_code")
  output    String?
  createdAt DateTime @default(now()) @map("created_at")

  build Build @relation(fields: [buildId], references: [id])

  @@map("build_steps")
}

// GitHub App 安装记录表
model GitHubInstallation {
  id             Int      @id @default(autoincrement())
  installationId Int      @unique @map("installation_id")
  accountLogin   String   @map("account_login")
  accountType    String   @map("account_type")
  accountId      Int      @map("account_id")
  avatarUrl      String?  @map("avatar_url")
  adminId        Int      @map("admin_id")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  admin Admin @relation(fields: [adminId], references: [id])

  @@map("github_installations")
}

// 仓库 CI/CD 配置表
model RepoConfig {
  id            Int      @id @default(autoincrement())
  repoId        Int      @map("repo_id")
  repoFullName  String   @map("repo_full_name")
  repoOwner     String   @map("repo_owner")
  repoName      String   @map("repo_name")
  enabled       Boolean  @default(false)
  adminId       Int      @map("admin_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  admin Admin @relation(fields: [adminId], references: [id])

  @@unique([repoId, adminId])
  @@map("repo_configs")
}

// API 密钥表
model ApiKey {
  id          Int      @id @default(autoincrement())
  keyHash     String   @unique @map("key_hash")
  name        String
  adminId     Int      @map("admin_id")
  lastUsedAt  DateTime? @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")
  isActive    Boolean  @default(true) @map("is_active")

  admin Admin @relation(fields: [adminId], references: [id])

  @@index([keyHash])
  @@map("api_keys")
}

// GitHub Actions 自托管 Runner 表
model GitHubRunner {
  id              Int      @id @default(autoincrement())
  name            String                           // Runner 显示名称
  scopeType       String   @map("scope_type")      // "repo" 或 "org"
  scopeTarget     String   @map("scope_target")    // 仓库全名(如 owner/repo) 或组织名
  labels          String[] @default(["self-hosted", "linux", "x64"])  // Runner 标签
  status          String   @default("idle")        // idle, running, stopped, error, offline
  registrationToken String? @map("registration_token") @db.Text  // GitHub 注册令牌（临时）
  runnerToken     String?  @map("runner_token") @db.Text         // Runner 永久令牌（加密存储）
  runnerId        Int?     @map("runner_id")       // GitHub Runner 数字 ID
  pid             Int?                              // PM2 进程 ID
  workDir         String?  @map("work_dir")        // Runner 工作目录路径
  lastError       String?  @map("last_error") @db.Text  // 最近一次错误信息
  adminId         Int      @map("admin_id")
  installationId  Int?     @map("installation_id") // 关联的 GitHub App 安装 ID
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  admin Admin @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([status])
  @@index([scopeType, scopeTarget])
  @@map("github_runners")
}
